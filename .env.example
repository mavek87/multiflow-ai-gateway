# Required
MASTER_KEY=your-secret-master-key
ENCRYPTION_KEY=your-64-hex-char-key

# Server
PORT=13000

# Database
DB_PATH=./data/gateway.db

# Audit log retention in days (default: 90)
# AUDIT_RETENTION_DAYS=90

# Model selector algorithm: thompson | ucb1-tuned | sw-ucb1-tuned
SELECTOR_TYPE=ucb1-tuned

# Logging level: trace | debug | info | warn | error
LOG_LEVEL=info

# Timeouts (milliseconds)
PROVIDER_STREAM_FIRST_TOKEN_TIMEOUT_MS=30000
PROVIDER_STREAM_WATCHDOG_MS=120000
PROVIDER_REQUEST_TIMEOUT_MS=30000

# TLS (optional — omit or leave empty for HTTP, set both for HTTPS)
# TLS_CERT=/etc/ssl/multiflow/cert.pem
# TLS_KEY=/etc/ssl/multiflow/key.pem
