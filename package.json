{
  "name": "multiflow-ai-gateway",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bunx drizzle-kit generate && bun --hot src/index.ts | bunx pino-pretty --messageFormat \"[{label}] {msg}\" --ignore \"pid,hostname,label\"",
    "start": "bunx drizzle-kit generate && bun src/index.ts",
    "test": "bun test src/",
    "typecheck": "bunx tsc --noEmit",
    "check": "bun run typecheck && bun run test",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pino": "^7.0.5",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "elysia": "^1.4.28",
    "@elysiajs/bearer": "^1.4.4",
    "@elysiajs/swagger": "^1.3.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "drizzle-orm": "^0.45.2",
    "neverthrow": "^8.2.0",
    "pino": "^10.3.1"
  }
}
