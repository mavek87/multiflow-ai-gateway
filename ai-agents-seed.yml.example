tenants:
  - name: ai-agents
    providers:
      - name: Pollinations
        apiKeyEnv: POLLINATIONS_API_KEY
        models:
          - name: openai
            priority: 1
      - name: Ollama Local
        models:
          - name: qwen3.5:397b-cloud
            priority: 2
          - name: gemini-3-flash-preview
            priority: 3
          - name: gemma4:31b-cloud
            priority: 4
          - name: deepseek-v3.2:cloud
            priority: 5